generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ------------------------------------------------------
// Better Auth core schema
// ------------------------------------------------------

model User {
  id            String    @id
  name          String
  email         String    @unique
  emailVerified Boolean
  image         String?
  createdAt     DateTime
  updatedAt     DateTime

  sessions             Session[]
  accounts             Account[]
  roles                UserRoleAssignment[]
  student              Student?
  guardian             Guardian?
  instructor           Instructor?
  staffProfile         StaffProfile?
  recordedAttendances  Attendance[]
  scannedCheckIns      CheckInLog[]
  receivedPayments     Payment[]
  createdFinancialNotes FinancialNote[]
  stockMovements       StockMovement[]
  pickupRecords        PickupRecord[]
  announcements        Announcement[]
  notifications        Notification[]
  statusChanges        StudentStatusHistory[]
  auditLogs            AuditLog[]

  @@map("user")
}

model Session {
  id        String   @id
  userId    String
  token     String   @unique
  expiresAt DateTime
  ipAddress String?
  userAgent String?
  createdAt DateTime
  updatedAt DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id
  userId                String
  accountId             String
  providerId            String
  accessToken           String?
  refreshToken          String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  idToken               String?
  password              String?
  createdAt             DateTime
  updatedAt             DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([providerId, accountId])
  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime?
  updatedAt  DateTime?

  @@index([identifier])
  @@map("verification")
}

// ------------------------------------------------------
// Enums
// ------------------------------------------------------

enum AppRole {
  ADMIN_MASTER
  ADMIN
  RECEPTION
  INSTRUCTOR
  STUDENT
  GUARDIAN
}

enum Gender {
  MALE
  FEMALE
  OTHER
  PREFER_NOT_TO_SAY
}

enum StudentStatus {
  LEAD
  TRIAL
  ACTIVE
  INACTIVE
  FROZEN
  CANCELED
  DELINQUENT
}

enum StudentGoal {
  HEALTH
  SELF_DEFENSE
  COMPETITION
  HOBBY
  CHILD_DEVELOPMENT
  OTHER
}

enum ClassLevel {
  ALL_LEVELS
  BEGINNER
  INTERMEDIATE
  ADVANCED
  COMPETITION
}

enum WeekDay {
  SUNDAY
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
}

enum EnrollmentStatus {
  ACTIVE
  PAUSED
  CANCELED
  COMPLETED
}

enum ClassSessionStatus {
  SCHEDULED
  OPEN
  CLOSED
  CANCELED
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
  EXCUSED
}

enum AttendanceSource {
  MANUAL
  QR_CODE
  ADMIN_ADJUSTMENT
}

enum CheckInMethod {
  QR_CODE
  MANUAL
  PIN
}

enum CheckInStatus {
  SUCCESS
  FAILED
}

enum PromotionType {
  BELT
  DEGREE
}

enum BillingCycle {
  MONTHLY
  QUARTERLY
  SEMIANNUAL
  ANNUAL
}

enum SubscriptionStatus {
  ACTIVE
  PAUSED
  CANCELED
  EXPIRED
}

enum InvoiceStatus {
  PENDING
  PAID
  OVERDUE
  CANCELED
  REFUNDED
}

enum PaymentMethod {
  CASH
  PIX
  CARD
  BANK_TRANSFER
}

enum StockMovementType {
  IN
  OUT
  ADJUSTMENT
}

enum OrderStatus {
  PENDING
  CONFIRMED
  CANCELED
  FULFILLED
}

enum PickupStatus {
  WAITING_SEPARATION
  READY_FOR_PICKUP
  PICKED_UP
}

enum AnnouncementType {
  INFO
  WARNING
  IMPORTANT
}

enum AnnouncementScope {
  ALL
  STUDENTS
  INSTRUCTORS
  STAFF
  CLASS_ONLY
}

// ------------------------------------------------------
// Core academy
// ------------------------------------------------------

model Academy {
  id             String   @id @default(cuid())
  name           String
  slug           String   @unique
  tradeName      String?
  email          String?
  phone          String?
  document       String?
  logoUrl        String?
  primaryColor   String?
  secondaryColor String?
  infoColor      String?
  timezone       String   @default("America/Fortaleza")
  currency       String   @default("BRL")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  settings            AcademySettings?
  userRoles           UserRoleAssignment[]
  students            Student[]
  guardians           Guardian[]
  instructors         Instructor[]
  staffProfiles       StaffProfile[]
  leadSources         LeadSource[]
  cancellationReasons CancellationReason[]
  classTypes          ClassType[]
  classes             Class[]
  belts               Belt[]
  plans               Plan[]
  productCategories   ProductCategory[]
  products            Product[]
  announcements       Announcement[]
  checkInLogs         CheckInLog[]
  invoices            Invoice[]
  orders              Order[]
  auditLogs           AuditLog[]
}

model AcademySettings {
  id                              String   @id @default(cuid())
  academyId                       String   @unique
  defaultMonthlyDueDay            Int      @default(10)
  allowQrCheckIn                  Boolean  @default(true)
  checkInWindowMinutesBeforeClass Int      @default(30)
  checkInWindowMinutesAfterClass  Int      @default(30)
  minimumAttendanceForPromotion   Int?
  allowStoreOrders                Boolean  @default(true)
  createdAt                       DateTime @default(now())
  updatedAt                       DateTime @updatedAt

  academy Academy @relation(fields: [academyId], references: [id], onDelete: Cascade)
}

model UserRoleAssignment {
  id        String   @id @default(cuid())
  academyId String
  userId    String
  role      AppRole
  createdAt DateTime @default(now())

  academy Academy @relation(fields: [academyId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([academyId, userId, role])
  @@index([userId])
  @@index([academyId, role])
}

// ------------------------------------------------------
// People
// ------------------------------------------------------

model Student {
  id                    String        @id @default(cuid())
  academyId             String
  userId                String?       @unique
  fullName              String
  preferredName         String?
  cpf                   String?       @unique
  email                 String?
  phone                 String?
  birthDate             DateTime?
  gender                Gender?
  photoUrl              String?
  status                StudentStatus @default(LEAD)
  joinDate              DateTime?
  exitDate              DateTime?
  leadSourceId          String?
  goal                  StudentGoal?
  hasPreviousExperience Boolean       @default(false)
  previousAcademy       String?
  notes                 String?
  medicalNotes          String?
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt

  academy             Academy              @relation(fields: [academyId], references: [id], onDelete: Cascade)
  user                User?                @relation(fields: [userId], references: [id], onDelete: SetNull)
  leadSource          LeadSource?          @relation(fields: [leadSourceId], references: [id], onDelete: SetNull)
  address             StudentAddress?
  guardians           StudentGuardian[]
  emergencyContacts   EmergencyContact[]
  enrollments         Enrollment[]
  attendances         Attendance[]
  checkInLogs         CheckInLog[]
  qrTokens            StudentQrToken[]
  beltStatus          StudentBeltStatus?
  graduationHistory   GraduationHistory[]
  evaluations         StudentEvaluation[]
  subscriptions       StudentSubscription[]
  invoices            Invoice[]
  financialNotes      FinancialNote[]
  orders              Order[]
  statusHistory       StudentStatusHistory[]
  announcementTargets AnnouncementTarget[]

  @@index([academyId, status])
  @@index([academyId, joinDate])
  @@index([leadSourceId])
}

model StudentAddress {
  id         String  @id @default(cuid())
  studentId  String  @unique
  zipCode    String?
  street     String?
  number     String?
  complement String?
  district   String?
  city       String?
  state      String?
  country    String? @default("Brasil")

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)
}

model Guardian {
  id                     String   @id @default(cuid())
  academyId              String
  userId                 String?  @unique
  fullName               String
  cpf                    String?  @unique
  email                  String?
  phone                  String?
  relationship           String?
  isFinancialResponsible Boolean  @default(true)
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  academy  Academy           @relation(fields: [academyId], references: [id], onDelete: Cascade)
  user     User?             @relation(fields: [userId], references: [id], onDelete: SetNull)
  students StudentGuardian[]

  @@index([academyId, fullName])
}

model StudentGuardian {
  id         String   @id @default(cuid())
  studentId  String
  guardianId String
  isPrimary  Boolean  @default(false)
  createdAt  DateTime @default(now())

  student  Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  guardian Guardian @relation(fields: [guardianId], references: [id], onDelete: Cascade)

  @@unique([studentId, guardianId])
  @@index([guardianId])
}

model EmergencyContact {
  id           String @id @default(cuid())
  studentId    String
  name         String
  phone        String?
  relationship String?

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([studentId])
}

model Instructor {
  id         String   @id @default(cuid())
  academyId  String
  userId     String?  @unique
  fullName   String
  email      String?
  phone      String?
  bio        String?
  hireDate   DateTime?
  birthDate  DateTime?
  belt       String?
  beltDegree Int?     @default(0)
  active     Boolean  @default(true)
  notes      String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  academy            Academy              @relation(fields: [academyId], references: [id], onDelete: Cascade)
  user               User?                @relation(fields: [userId], references: [id], onDelete: SetNull)
  classes            Class[]
  classSessions      ClassSession[]
  graduationHistory  GraduationHistory[]
  evaluations        StudentEvaluation[]

  @@index([academyId, active])
}

model StaffProfile {
  id        String   @id @default(cuid())
  academyId String
  userId    String   @unique
  position  String
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  academy Academy @relation(fields: [academyId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([academyId, active])
}

model LeadSource {
  id        String   @id @default(cuid())
  academyId String
  name      String
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  academy  Academy   @relation(fields: [academyId], references: [id], onDelete: Cascade)
  students Student[]

  @@unique([academyId, name])
}

model CancellationReason {
  id        String   @id @default(cuid())
  academyId String
  name      String
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  academy       Academy               @relation(fields: [academyId], references: [id], onDelete: Cascade)
  statusHistory StudentStatusHistory[]

  @@unique([academyId, name])
}

// ------------------------------------------------------
// Classes and schedules
// ------------------------------------------------------

model ClassType {
  id          String     @id @default(cuid())
  academyId   String
  name        String
  description String?
  minAge      Int?
  maxAge      Int?
  level       ClassLevel @default(ALL_LEVELS)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  academy Academy @relation(fields: [academyId], references: [id], onDelete: Cascade)
  classes Class[]

  @@unique([academyId, name])
}

model Class {
  id                 String   @id @default(cuid())
  academyId          String
  classTypeId        String
  instructorId       String?
  name               String
  description        String?
  location           String?
  capacity           Int?
  active             Boolean  @default(true)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  academy             Academy              @relation(fields: [academyId], references: [id], onDelete: Cascade)
  classType           ClassType            @relation(fields: [classTypeId], references: [id], onDelete: Restrict)
  instructor          Instructor?          @relation(fields: [instructorId], references: [id], onDelete: SetNull)
  schedules           ClassSchedule[]
  enrollments         Enrollment[]
  sessions            ClassSession[]
  announcementTargets AnnouncementTarget[]

  @@index([academyId, active])
  @@index([classTypeId])
  @@index([instructorId])
}

model ClassSchedule {
  id                           String   @id @default(cuid())
  classId                      String
  weekDay                      WeekDay
  startTime                    String
  endTime                      String
  checkInStartsAtOffsetMinutes Int?
  checkInEndsAtOffsetMinutes   Int?
  createdAt                    DateTime @default(now())
  updatedAt                    DateTime @updatedAt

  class    Class          @relation(fields: [classId], references: [id], onDelete: Cascade)
  sessions ClassSession[]

  @@index([classId, weekDay])
}

model Enrollment {
  id        String           @id @default(cuid())
  studentId String
  classId   String
  startDate DateTime
  endDate   DateTime?
  status    EnrollmentStatus @default(ACTIVE)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)
  class   Class   @relation(fields: [classId], references: [id], onDelete: Cascade)

  @@index([studentId, status])
  @@index([classId, status])
}

// ------------------------------------------------------
// Sessions, attendance and QR
// ------------------------------------------------------

model ClassSession {
  id              String             @id @default(cuid())
  classId         String
  classScheduleId String?
  instructorId    String?
  sessionDate     DateTime
  startsAt        DateTime
  endsAt          DateTime
  status          ClassSessionStatus @default(SCHEDULED)
  notes           String?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  class         Class          @relation(fields: [classId], references: [id], onDelete: Cascade)
  classSchedule ClassSchedule? @relation(fields: [classScheduleId], references: [id], onDelete: SetNull)
  instructor    Instructor?    @relation(fields: [instructorId], references: [id], onDelete: SetNull)
  attendances   Attendance[]
  checkInLogs   CheckInLog[]

  @@index([classId, sessionDate])
  @@index([status])
}

model Attendance {
  id               String           @id @default(cuid())
  classSessionId   String
  studentId        String
  status           AttendanceStatus @default(PRESENT)
  source           AttendanceSource @default(MANUAL)
  checkedInAt      DateTime?
  checkedOutAt     DateTime?
  recordedByUserId String?
  notes            String?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  classSession ClassSession @relation(fields: [classSessionId], references: [id], onDelete: Cascade)
  student      Student      @relation(fields: [studentId], references: [id], onDelete: Cascade)
  recordedBy   User?        @relation(fields: [recordedByUserId], references: [id], onDelete: SetNull)

  @@unique([classSessionId, studentId])
  @@index([studentId, status])
}

model CheckInLog {
  id              String        @id @default(cuid())
  academyId       String
  studentId       String
  classSessionId  String?
  tokenId         String?
  method          CheckInMethod
  scannedByUserId String?
  deviceInfo      Json?
  checkedInAt     DateTime      @default(now())
  status          CheckInStatus
  failureReason   String?

  academy      Academy         @relation(fields: [academyId], references: [id], onDelete: Cascade)
  student      Student         @relation(fields: [studentId], references: [id], onDelete: Cascade)
  classSession ClassSession?   @relation(fields: [classSessionId], references: [id], onDelete: SetNull)
  token        StudentQrToken? @relation(fields: [tokenId], references: [id], onDelete: SetNull)
  scannedBy    User?           @relation(fields: [scannedByUserId], references: [id], onDelete: SetNull)

  @@index([academyId, checkedInAt])
  @@index([studentId, checkedInAt])
  @@index([classSessionId])
}

model StudentQrToken {
  id         String   @id @default(cuid())
  studentId  String
  codeHash   String   @unique
  expiresAt  DateTime?
  isActive   Boolean  @default(true)
  lastUsedAt DateTime?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)
  logs    CheckInLog[]

  @@index([studentId, isActive])
}

// ------------------------------------------------------
// Graduation
// ------------------------------------------------------

model Belt {
  id               String   @id @default(cuid())
  academyId        String
  name             String
  color            String
  sortOrder        Int
  adultCategory    Boolean  @default(true)
  juvenileCategory Boolean  @default(false)
  active           Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  academy         Academy             @relation(fields: [academyId], references: [id], onDelete: Cascade)
  degrees         BeltDegree[]
  currentStudents StudentBeltStatus[]
  graduationFrom  GraduationHistory[] @relation("GraduationFromBelt")
  graduationTo    GraduationHistory[] @relation("GraduationToBelt")

  @@unique([academyId, sortOrder])
  @@unique([academyId, name])
}

model BeltDegree {
  id           String   @id @default(cuid())
  beltId       String
  degreeNumber Int
  sortOrder    Int
  createdAt    DateTime @default(now())

  belt            Belt                @relation(fields: [beltId], references: [id], onDelete: Cascade)
  currentStudents StudentBeltStatus[]
  graduationFrom  GraduationHistory[] @relation("GraduationFromDegree")
  graduationTo    GraduationHistory[] @relation("GraduationToDegree")

  @@unique([beltId, degreeNumber])
}

model StudentBeltStatus {
  id              String    @id @default(cuid())
  studentId       String    @unique
  currentBeltId   String
  currentDegreeId String?
  promotedAt      DateTime?
  notes           String?
  updatedAt       DateTime  @updatedAt

  student       Student     @relation(fields: [studentId], references: [id], onDelete: Cascade)
  currentBelt   Belt        @relation(fields: [currentBeltId], references: [id], onDelete: Restrict)
  currentDegree BeltDegree? @relation(fields: [currentDegreeId], references: [id], onDelete: SetNull)
}

model GraduationHistory {
  id                     String        @id @default(cuid())
  studentId              String
  fromBeltId             String?
  fromDegreeId           String?
  toBeltId               String
  toDegreeId             String?
  promotionType          PromotionType
  promotedAt             DateTime
  approvedByInstructorId String?
  notes                  String?
  createdAt              DateTime      @default(now())

  student              Student     @relation(fields: [studentId], references: [id], onDelete: Cascade)
  fromBelt             Belt?       @relation("GraduationFromBelt", fields: [fromBeltId], references: [id], onDelete: SetNull)
  fromDegree           BeltDegree? @relation("GraduationFromDegree", fields: [fromDegreeId], references: [id], onDelete: SetNull)
  toBelt               Belt        @relation("GraduationToBelt", fields: [toBeltId], references: [id], onDelete: Restrict)
  toDegree             BeltDegree? @relation("GraduationToDegree", fields: [toDegreeId], references: [id], onDelete: SetNull)
  approvedByInstructor Instructor? @relation(fields: [approvedByInstructorId], references: [id], onDelete: SetNull)

  @@index([studentId, promotedAt])
  @@index([toBeltId])
}

model StudentEvaluation {
  id              String   @id @default(cuid())
  studentId       String
  instructorId    String
  technicalScore  Int?
  disciplineScore Int?
  attendanceScore Int?
  notes           String?
  createdAt       DateTime @default(now())

  student    Student    @relation(fields: [studentId], references: [id], onDelete: Cascade)
  instructor Instructor @relation(fields: [instructorId], references: [id], onDelete: Cascade)

  @@index([studentId, createdAt])
  @@index([instructorId])
}

// ------------------------------------------------------
// Finance
// ------------------------------------------------------

model Plan {
  id           String       @id @default(cuid())
  academyId    String
  name         String
  description  String?
  priceInCents Int
  billingCycle BillingCycle
  active       Boolean      @default(true)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  academy       Academy                @relation(fields: [academyId], references: [id], onDelete: Cascade)
  subscriptions StudentSubscription[]

  @@unique([academyId, name])
  @@index([academyId, active])
}

model StudentSubscription {
  id              String             @id @default(cuid())
  studentId       String
  planId          String
  startsAt        DateTime
  endsAt          DateTime?
  status          SubscriptionStatus @default(ACTIVE)
  priceInCents    Int
  discountInCents Int                @default(0)
  billingDueDay   Int
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  student  Student   @relation(fields: [studentId], references: [id], onDelete: Cascade)
  plan     Plan      @relation(fields: [planId], references: [id], onDelete: Restrict)
  invoices Invoice[]

  @@index([studentId, status])
  @@index([planId])
}

model Invoice {
  id              String        @id @default(cuid())
  academyId       String
  studentId       String
  subscriptionId  String?
  description     String
  amountInCents   Int
  discountInCents Int           @default(0)
  fineInCents     Int           @default(0)
  dueDate         DateTime
  paidAt          DateTime?
  status          InvoiceStatus @default(PENDING)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  academy      Academy              @relation(fields: [academyId], references: [id], onDelete: Cascade)
  student      Student              @relation(fields: [studentId], references: [id], onDelete: Cascade)
  subscription StudentSubscription? @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)
  payments     Payment[]

  @@index([academyId, status, dueDate])
  @@index([studentId, status])
}

model Payment {
  id               String        @id @default(cuid())
  invoiceId        String
  amountInCents    Int
  method           PaymentMethod
  paidAt           DateTime
  receivedByUserId String?
  reference        String?
  notes            String?
  createdAt        DateTime      @default(now())

  invoice    Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  receivedBy User?   @relation(fields: [receivedByUserId], references: [id], onDelete: SetNull)

  @@index([invoiceId])
  @@index([paidAt])
}

model FinancialNote {
  id              String   @id @default(cuid())
  studentId       String
  createdByUserId String
  note            String
  createdAt       DateTime @default(now())

  student   Student @relation(fields: [studentId], references: [id], onDelete: Cascade)
  createdBy User    @relation(fields: [createdByUserId], references: [id], onDelete: Cascade)

  @@index([studentId, createdAt])
}

// ------------------------------------------------------
// Store
// ------------------------------------------------------

model ProductCategory {
  id        String   @id @default(cuid())
  academyId String
  name      String
  slug      String
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  academy  Academy   @relation(fields: [academyId], references: [id], onDelete: Cascade)
  products Product[]

  @@unique([academyId, slug])
  @@unique([academyId, name])
}

model Product {
  id            String   @id @default(cuid())
  academyId     String
  categoryId    String
  name          String
  slug          String
  description   String?
  sku           String?  @unique
  priceInCents  Int
  costInCents   Int?
  stockQuantity Int      @default(0)
  imageUrl      String?
  active        Boolean  @default(true)
  pickupOnly    Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  academy        Academy         @relation(fields: [academyId], references: [id], onDelete: Cascade)
  category       ProductCategory @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  stockMovements StockMovement[]
  orderItems     OrderItem[]

  @@unique([academyId, slug])
  @@index([academyId, active])
  @@index([categoryId])
}

model StockMovement {
  id              String            @id @default(cuid())
  productId       String
  type            StockMovementType
  quantity        Int
  reason          String?
  createdByUserId String
  createdAt       DateTime          @default(now())

  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  createdBy User    @relation(fields: [createdByUserId], references: [id], onDelete: Cascade)

  @@index([productId, createdAt])
}

model Order {
  id              String       @id @default(cuid())
  academyId       String
  studentId       String
  status          OrderStatus  @default(PENDING)
  subtotalInCents Int
  discountInCents Int          @default(0)
  totalInCents    Int
  pickupStatus    PickupStatus @default(WAITING_SEPARATION)
  pickupReadyAt   DateTime?
  pickedUpAt      DateTime?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  academy       Academy        @relation(fields: [academyId], references: [id], onDelete: Cascade)
  student       Student        @relation(fields: [studentId], references: [id], onDelete: Cascade)
  items         OrderItem[]
  pickupRecords PickupRecord[]

  @@index([academyId, status, createdAt])
  @@index([studentId, createdAt])
}

model OrderItem {
  id                  String @id @default(cuid())
  orderId             String
  productId           String
  productNameSnapshot String
  unitPriceInCents    Int
  quantity            Int
  lineTotalInCents    Int

  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Restrict)

  @@index([orderId])
}

model PickupRecord {
  id                 String   @id @default(cuid())
  orderId            String
  pickedUpByName     String
  pickedUpByDocument String?
  confirmedByUserId  String
  pickedUpAt         DateTime
  notes              String?

  order       Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
  confirmedBy User  @relation(fields: [confirmedByUserId], references: [id], onDelete: Cascade)

  @@index([orderId, pickedUpAt])
}

// ------------------------------------------------------
// Communication
// ------------------------------------------------------

model Announcement {
  id              String            @id @default(cuid())
  academyId       String
  title           String
  content         String
  type            AnnouncementType  @default(INFO)
  visibilityScope AnnouncementScope @default(ALL)
  publishedAt     DateTime?
  expiresAt       DateTime?
  createdByUserId String
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  academy   Academy              @relation(fields: [academyId], references: [id], onDelete: Cascade)
  createdBy User                 @relation(fields: [createdByUserId], references: [id], onDelete: Cascade)
  targets   AnnouncementTarget[]

  @@index([academyId, publishedAt])
  @@index([visibilityScope])
}

model AnnouncementTarget {
  id             String   @id @default(cuid())
  announcementId String
  classId        String?
  role           AppRole?
  studentId      String?

  announcement Announcement @relation(fields: [announcementId], references: [id], onDelete: Cascade)
  class        Class?       @relation(fields: [classId], references: [id], onDelete: Cascade)
  student      Student?     @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([announcementId])
  @@index([classId])
  @@index([studentId])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  title     String
  message   String
  type      String?
  readAt    DateTime?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, readAt])
}

// ------------------------------------------------------
// History and analytics
// ------------------------------------------------------

model StudentStatusHistory {
  id              String        @id @default(cuid())
  studentId       String
  fromStatus      StudentStatus?
  toStatus        StudentStatus
  changedAt       DateTime      @default(now())
  changedByUserId String?
  reasonId        String?
  notes           String?

  student   Student             @relation(fields: [studentId], references: [id], onDelete: Cascade)
  changedBy User?               @relation(fields: [changedByUserId], references: [id], onDelete: SetNull)
  reason    CancellationReason? @relation(fields: [reasonId], references: [id], onDelete: SetNull)

  @@index([studentId, changedAt])
  @@index([toStatus, changedAt])
  @@index([reasonId])
}

model AuditLog {
  id         String   @id @default(cuid())
  academyId  String
  userId     String?
  entityType String
  entityId   String
  action     String
  metadata   Json?
  createdAt  DateTime @default(now())

  academy Academy @relation(fields: [academyId], references: [id], onDelete: Cascade)
  user    User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([academyId, createdAt])
  @@index([entityType, entityId])
}